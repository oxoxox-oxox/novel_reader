{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Novel Reader",
    "version": "0.1.0"
  },
  "tauri": {
    "windows": [
      {
        "title": "Novel Reader",
        "width": 1200,
        "height": 760,
        "resizable": true
      }
    ],
    "allowlist": {
      "fs": {
        "all": false,
        "readFile": true,
        "readDir": true
      },
      "dialog": {
        "open": true
      },
      "path": {
        "all": true
      }
    }
  }
}
